#include<iostream>
using namespace std;
int fact(int n){
    int fact=1;
    for(int i=1; i<=n; i++){
        fact=fact*i;
    }
    return fact;
}
int main(){
    int n;
    cin>>n;
    int r;
    cin>>r;
    int binomial_coeff=fact(n)/(fact(n-r)*fact(r));
    cout<<"the binomial coeff "<<binomial_coeff;


}
